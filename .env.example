# 親亡き後支援データベース 設定ファイル
# このファイルを .env にコピーして設定してください
# cp .env.example .env

# --- Gemini API (AI抽出・セマンティック検索・OCRに必要) ---
# Gemini 2.0 Flash: テキスト構造化抽出、スキャンPDF/画像OCR
# Gemini Embedding 2: セマンティック検索用ベクトル生成
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Neo4j データベース接続 ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# --- デモモード (オプション) ---
# DEMO_MODE=true

# --- 仮名化設定 (オプション) ---
# PSEUDONYMIZATION_ENABLED=false
